# instance.env — customer-layer environment variables consumed by E.V.E. scripts.
#
# Lives at:  ~/.config/eve/instance.env  (NOT committed to any repo)
# Format:    Bourne shell `KEY=VALUE` (sourced by .sh; parsed by eve_config.py)
# Owner:     populated by the customer-onboarding dashboard (Phase 2.5)
#            until the dashboard exists, hand-edit per box
#
# This template is for documentation only. Copy it to ~/.config/eve/instance.env,
# fill in real values, then `chmod 600 ~/.config/eve/instance.env`.
#
# Scripts that need a value MUST fail loudly if the env var is missing — never
# silently fall back to a hardcoded L&R value. The lone exception is paths
# with safe defaults (EVE_VAULT defaults to ~/EveBrain).

# ─── Instance identity ──────────────────────────────────────────────────────
# The persona name this customer picked for their instance (e.g. "Eve", "Iris",
# "Atlas"). Used in sign-offs and self-references.
EVE_INSTANCE_NAME="Eve"

# Eve's primary Google Workspace account (the automation/persona inbox).
# All Workspace MCP calls default to this account.
EVE_INSTANCE_EMAIL="Eve@labrasseurandreich.com"

# The customer company's primary domain. Used for sign-off ("Eve @ <Company>")
# and to detect "internal" recipients.
EVE_INSTANCE_DOMAIN="labrasseurandreich.com"

# Short company name for signatures (e.g. "L&R", "Acme").
EVE_INSTANCE_COMPANY_SHORT="L&R"

# ─── Vault location ─────────────────────────────────────────────────────────
# Customer's vault root (Obsidian dir). Default is fine for almost everyone.
EVE_VAULT="${HOME}/EveBrain"

# ─── Team members (up to 8 — extend the schema if you need more) ────────────
# For each teammate the customer wants Eve to know about, fill in:
#   - EMAIL: their primary work email (used for Workspace MCP per-user calls)
#   - NAME: short display name
#   - SCOPES: comma-separated subset of {calendar,mail,drive,chat,tasks}
#   - PERSONAL_EMAIL (optional): personal Gmail if Eve also reads that
#   - WHATSAPP_JID (optional): for WhatsApp DMs
#   - CHAT_SPACE (optional): preferred Google Chat space ID for personal messages

EVE_TEAM_1_EMAIL="alexander.reich@labrasseurandreich.com"
EVE_TEAM_1_NAME="Alex"
EVE_TEAM_1_SCOPES="calendar,mail,drive,chat"
EVE_TEAM_1_PERSONAL_EMAIL="alexander.reich.la@gmail.com"
EVE_TEAM_1_WHATSAPP_JID="133324425179144@lid"
EVE_TEAM_1_CHAT_SPACE="spaces/AAQA5xkWJq0"

EVE_TEAM_2_EMAIL="shawn.labrasseur@labrasseurandreich.com"
EVE_TEAM_2_NAME="Shawn"
EVE_TEAM_2_SCOPES="calendar,mail,drive,chat"
EVE_TEAM_2_CHAT_SPACE="spaces/AAQAsY1M6_g"
# EVE_TEAM_2_WHATSAPP_JID=""
# EVE_TEAM_2_PERSONAL_EMAIL=""

# EVE_TEAM_3_EMAIL=""
# ...

# ─── Backup ─────────────────────────────────────────────────────────────────
# Path to the Workspace OAuth credentials JSON used by backup_to_drive.py.
# Default points to the customer's instance email file.
EVE_BACKUP_CREDS_FILE="${HOME}/.google_workspace_mcp/credentials/${EVE_INSTANCE_EMAIL}.json"

# Google Drive folder ID where encrypted backups are uploaded.
# Get this by opening the folder in Drive and copying the ID from the URL.
# Each customer creates their own backup folder; no shared default.
EVE_BACKUP_FOLDER_ID="REPLACE_WITH_YOUR_DRIVE_FOLDER_ID"

# Label for the backup archive in Drive (just for human-readable filenames).
EVE_BACKUP_LABEL="EveBrain"

# ─── Outbound user-agent ────────────────────────────────────────────────────
# Used by web_fetch.py + research_property.py when hitting external services.
# Identifies this E.V.E. instance to the remote (so admins can reach you if
# scraping volume is a concern).
EVE_USER_AGENT="Eve/${EVE_INSTANCE_COMPANY_SHORT}/1.0 (${EVE_INSTANCE_EMAIL})"

# ─── (Future) per-skill toggles ─────────────────────────────────────────────
# Skills the customer has enabled. Empty / commented = skill stays off.
# EVE_SKILLS="news,daily_brief,bts_sweep,plaud,backup"
